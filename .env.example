# Rename this file to .env and set one provider + matching key.

# Common model settings
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Provider keys (set only what you use)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# For OpenAI-compatible endpoints (OpenRouter, Together, local vLLM, etc.)
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=your_openai_compatible_key_here
